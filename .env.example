# BenchBook.AI Environment Configuration

# ============================================================================
# Core Application
# ============================================================================
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================================================
# Supabase Configuration
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================================
# AI Configuration (Claude API) - NEW
# ============================================================================

# Anthropic Claude API Key (required for AI functionality)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# Feature flags for AI functionality
USE_CLAUDE_API=true
ENABLE_PROMPT_CACHING=true

# Model configuration
CLAUDE_HAIKU_MODEL=claude-3-5-haiku-20241022
CLAUDE_SONNET_MODEL=claude-3-5-sonnet-20241022

# Cache settings
CORPUS_CACHE_TTL_MINUTES=5

# ============================================================================
# Legacy AI Configuration (REMOVED)
# ============================================================================

# The following environment variables are NO LONGER NEEDED:
# OPENAI_API_KEY=sk-...          # Replaced by ANTHROPIC_API_KEY
# PINECONE_API_KEY=...           # Eliminated (using direct context loading)
# PINECONE_HOST=...              # Eliminated (using direct context loading)

# ============================================================================
# Application Pricing Configuration
# ============================================================================

# Subscription pricing (used in billing components)
NEXT_PUBLIC_SOLO_PRICE_MONTHLY=79
NEXT_PUBLIC_SOLO_PRICE_YEARLY=790
NEXT_PUBLIC_COURT_PRICE_MONTHLY=229
NEXT_PUBLIC_COURT_PRICE_YEARLY=2290

# ============================================================================
# Development & Debugging
# ============================================================================

# Enable development features
NEXT_PUBLIC_DEBUG=false

# Mock AI responses (for development without API keys)
USE_MOCK_RESPONSES=false

# Legal corpus path (relative to project root)
LEGAL_CORPUS_PATH=./legal-corpus

# ============================================================================
# Analytics & Monitoring (Optional)
# ============================================================================

# Uncomment and configure these for production monitoring
# NEXT_PUBLIC_ANALYTICS_ID=
# SENTRY_DSN=
# POSTHOG_KEY=

# ============================================================================
# Email Configuration (Optional)
# ============================================================================

# For transactional emails (welcome, billing, etc.)
# EMAIL_SMTP_HOST=
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_USER=
# EMAIL_SMTP_PASSWORD=

# ============================================================================
# Deployment Configuration
# ============================================================================

# For Cloudflare Workers deployment
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ZONE_ID=