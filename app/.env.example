# BenchBook AI - Frontend Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase (required for auth and database)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Anthropic Claude AI (required for AI chat)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
USE_CLAUDE_API=true
ENABLE_PROMPT_CACHING=true

# Model Configuration (defaults to latest if not set)
CLAUDE_HAIKU_MODEL=claude-haiku-4-5-20250414
CLAUDE_SONNET_MODEL=claude-sonnet-4-5-20250414

# Legal Corpus
LEGAL_CORPUS_PATH=./legal-corpus
CORPUS_CACHE_TTL_MINUTES=5

# LangSmith (tracing - optional)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your-langsmith-api-key
